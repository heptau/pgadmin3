#include "wx/mstream.h"

static wxImage *pgAdmin3_256_png_img()
{
	if (!wxImage::FindHandler(wxT("PNG file")))
		wxImage::AddHandler(new wxPNGHandler());
	static wxImage *img_pgAdmin3_256_png = new wxImage();
	if (!img_pgAdmin3_256_png || !img_pgAdmin3_256_png->IsOk())
	{
		wxMemoryInputStream img_pgAdmin3_256_pngIS(pgAdmin3_256_png_data, sizeof(pgAdmin3_256_png_data));
		img_pgAdmin3_256_png->LoadFile(img_pgAdmin3_256_pngIS, wxBITMAP_TYPE_PNG);
	}
	return img_pgAdmin3_256_png;
}
#define pgAdmin3_256_png_img pgAdmin3_256_png_img()

static wxBitmap *pgAdmin3_256_png_bmp()
{
	static wxBitmap *bmp_pgAdmin3_256_png;
	if (!bmp_pgAdmin3_256_png || !bmp_pgAdmin3_256_png->IsOk())
		bmp_pgAdmin3_256_png = new wxBitmap(*pgAdmin3_256_png_img);
	return bmp_pgAdmin3_256_png;
}
#define pgAdmin3_256_png_bmp pgAdmin3_256_png_bmp()

static wxIcon *pgAdmin3_256_png_ico()
{
	static wxIcon *ico_pgAdmin3_256_png;
	if (!ico_pgAdmin3_256_png || !ico_pgAdmin3_256_png->IsOk())
	{
		ico_pgAdmin3_256_png = new wxIcon();
		ico_pgAdmin3_256_png->CopyFromBitmap(*pgAdmin3_256_png_bmp);
	}
	return ico_pgAdmin3_256_png;
}
#define pgAdmin3_256_png_ico pgAdmin3_256_png_ico()

