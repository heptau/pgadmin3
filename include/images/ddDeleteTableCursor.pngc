	if (!bmp_ddDeleteTableCursor_png || !bmp_ddDeleteTableCursor_png->IsOk())
		bmp_ddDeleteTableCursor_png = new wxBitmap(*ddDeleteTableCursor_png_img);
	return bmp_ddDeleteTableCursor_png;
}
#define ddDeleteTableCursor_png_bmp ddDeleteTableCursor_png_bmp()

static wxIcon *ddDeleteTableCursor_png_ico()
{
